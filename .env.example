# ── LLM 設定 ──────────────────────────────────────────────────────────────────
# 地端 LLM 的 OpenAI-compatible base URL
LLM_BASE_URL=http://192.168.1.100:8000/v1

# API Key（地端 LLM 若不需要驗證可填任意字串）
LLM_API_KEY=your-api-key-here

# 呼叫時使用的 model name（需與 LLM server 支援的名稱一致）
LLM_MODEL=gpt-oss-120b

# ── Webhook 伺服器設定（使用 webhook_server.py 才需要）─────────────────────────
# Bitbucket Server 網址
BITBUCKET_BASE_URL=http://co-git

# Bitbucket Personal Access Token（需有 repo 讀寫權限）
BITBUCKET_TOKEN=your-bitbucket-token-here

# Webhook 驗證 secret（在 Bitbucket webhook 設定填入同一組）
WEBHOOK_SECRET=your-webhook-secret-here

# webhook server 監聽 port
WEBHOOK_PORT=8000

# repo clone 暫存目錄
REPO_CLONE_DIR=/tmp/code-review-repos
